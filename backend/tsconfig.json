{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"],

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "sourceMap": true,

    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}